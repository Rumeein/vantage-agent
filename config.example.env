# Copy this to your business vantage/ folder as .env
# Never commit .env to git

# LLM API Keys (only the one matching your business_profile.json provider)
ANTHROPIC_API_KEY=your_anthropic_api_key_here
OPENAI_API_KEY=your_openai_api_key_here

# Telegram Bot (get from @BotFather)
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here

# Your Telegram chat ID (get from @userinfobot)
# Comma-separated if multiple users allowed
TELEGRAM_ALLOWED_CHAT_IDS=123456789
